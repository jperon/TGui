#!/bin/bash
# Pre-commit hook to ensure ALL tests pass before committing

echo "🧪 Running tests before commit..."

# Run tests and capture exit code
make test
TEST_EXIT_CODE=$?

if [ $TEST_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ COMMIT REJECTED: Tests failed!"
    echo "ALL tests must pass before committing."
    echo ""
    echo "Run 'make test' to see the full test output."
    exit 1
fi

echo "✅ All tests passed - commit allowed"
exit 0
