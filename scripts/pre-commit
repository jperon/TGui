#!/bin/bash
# Pre-commit hook to ensure CI checks pass before committing

echo "🧪 Running CI checks before commit..."

# Run CI and capture exit code
make ci
CI_EXIT_CODE=$?

if [ $CI_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ COMMIT REJECTED: CI checks failed!"
    echo "All CI checks must pass before committing."
    echo ""
    echo "Run 'make ci' to see the full output."
    exit 1
fi

echo "✅ CI checks passed - commit allowed"
exit 0
