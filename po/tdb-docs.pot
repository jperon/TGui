#: doc/en/reference.md:375
msgid "### Filtering"
msgstr ""

#: doc/en/reference.md:377
msgid "The API supports composable filtering:"
msgstr ""

#: doc/en/reference.md:381 doc/en/reference.md:416 doc/en/reference.md:427
msgid "  records("
msgstr ""

#: doc/en/reference.md:382
msgid "    spaceId: \"...\""
msgstr ""

#: doc/en/reference.md:383
msgid "    filter: {"
msgstr ""

#: doc/en/reference.md:384
msgid "      or: ["
msgstr ""

#: doc/en/reference.md:385
msgid "        { field: \"titre\", op: STARTS_WITH, value: \"Le\" }"
msgstr ""

#: doc/en/reference.md:386
msgid "        { field: \"annee\", op: GTE, value: \"2000\" }"
msgstr ""

#: doc/en/reference.md:387
msgid "      ]"
msgstr ""

#: doc/en/reference.md:389
msgid "    limit: 50"
msgstr ""

#: doc/en/reference.md:390
msgid "    offset: 0"
msgstr ""

#: doc/en/reference.md:391 doc/en/reference.md:419 doc/en/reference.md:430
msgid "  ) {"
msgstr ""

#: doc/en/reference.md:392 doc/en/reference.md:420 doc/en/reference.md:431 doc/en/api.md:167
msgid "    items { id data }"
msgstr ""

#: doc/en/reference.md:393 doc/en/reference.md:421 doc/en/reference.md:432 doc/en/api.md:166
msgid "    total"
msgstr ""

#: doc/en/reference.md:398
msgid "### Filter operators"
msgstr ""

#: doc/en/reference.md:400
msgid "| Operator      | Meaning |"
msgstr ""

#: doc/en/reference.md:401
msgid "|---------------|---------|"
msgstr ""

#: doc/en/reference.md:402
msgid "| `EQ`          | Equal to |"
msgstr ""

#: doc/en/reference.md:403
msgid "| `NEQ`         | Not equal to |"
msgstr ""

#: doc/en/reference.md:404
msgid "| `LT` / `GT`   | Less / greater (strict) |"
msgstr ""

#: doc/en/reference.md:405
msgid "| `LTE` / `GTE` | Less / greater or equal |"
msgstr ""

#: doc/en/reference.md:406
msgid "| `CONTAINS`    | Contains substring |"
msgstr ""

#: doc/en/reference.md:407
msgid "| `STARTS_WITH` | Starts with |"
msgstr ""

#: doc/en/reference.md:409
msgid "### Formula filters and FK traversal"
msgstr ""

#: doc/en/reference.md:411
msgid "In addition to field/operator filters, you can express arbitrary conditions in **MoonScript** via `formula`. These formulas have access to the **FK proxy**: relation fields are automatically resolved to the linked record, and multi-level chaining is supported."
msgstr ""

#: doc/en/reference.md:414
msgid "# Filter books whose genre is 'Roman' (via FK traversal)"
msgstr ""

#: doc/en/reference.md:417
msgid "    spaceId: \"livres-id\""
msgstr ""

#: doc/en/reference.md:418
msgid "    filter: { formula: \"@genre_id.libelle == 'Roman'\", language: \"moonscript\" }"
msgstr ""

#: doc/en/reference.md:425
msgid "# Filter copies whose book belongs to genre 'Polar' (2 levels)"
msgstr ""

#: doc/en/reference.md:428
msgid "    spaceId: \"exemplaires-id\""
msgstr ""

#: doc/en/reference.md:429
msgid "    filter: { formula: \"@livre_id.genre_id.libelle == 'Polar'\", language: \"moonscript\" }"
msgstr ""

#: doc/en/reference.md:437
msgid "FK formulas also work in **dynamic queries** generated for each space:"
msgstr ""

#: doc/en/reference.md:441
msgid "  livres(filter: { formula: \"@genre_id.libelle == 'Roman'\", language: \"moonscript\" }) {"
msgstr ""

#: doc/en/reference.md:442
msgid "    items { titre }"
msgstr ""

#: doc/en/reference.md:447
msgid "> **Note:** FK resolution first tries direct access by primary key (efficient), with fallback to a full scan for non-PK references. For large spaces, prefer classic field filters when possible."
msgstr ""

#: doc/en/reference.md:452
msgid "# Read records"
msgstr ""

#: doc/en/reference.md:454
msgid "  records(spaceId: \"...\", limit: 100) {"
msgstr ""

#: doc/en/reference.md:455
msgid "    items { id data } total"
msgstr ""

#: doc/en/reference.md:459
msgid "# Read a single record"
msgstr ""

#: doc/en/reference.md:460
msgid "query { record(spaceId: \"...\", id: \"42\") { id data } }"
msgstr ""

#: doc/en/reference.md:462
msgid "# Insert an author"
msgstr ""

#: doc/en/reference.md:464 doc/en/reference.md:472 doc/en/reference.md:480
msgid "  insertRecord("
msgstr ""

#: doc/en/reference.md:466
msgid "    data: { nom: \"Hugo\", prenom: \"Victor\", particule: \"\" }"
msgstr ""

#: doc/en/reference.md:467 doc/en/reference.md:475 doc/en/reference.md:483
msgid "  ) { id data }"
msgstr ""

#: doc/en/reference.md:470
msgid "# Insert a book"
msgstr ""

#: doc/en/reference.md:474
msgid "    data: { titre: \"Les Misérables\", auteur_id: 1, genre_id: 2, annee: 1862, isbn: \"978-2-07-040850-4\" }"
msgstr ""

#: doc/en/reference.md:478
msgid "# Insert a copy"
msgstr ""

#: doc/en/reference.md:482
msgid "    data: { livre_id: 1, etat: \"bon\", disponible: true }"
msgstr ""

#: doc/en/reference.md:486 doc/en/reference.md:514 doc/en/reference.md:673
msgid "# Update"
msgstr ""

#: doc/en/reference.md:488
msgid "  updateRecord(spaceId: \"...\", id: \"42\", data: { nom: \"Martin\" }) {"
msgstr ""

#: doc/en/reference.md:489
msgid "    id data"
msgstr ""

#: doc/en/reference.md:494
msgid "mutation { deleteRecord(spaceId: \"...\", id: \"42\") }"
msgstr ""

#: doc/en/reference.md:499
msgid "## 5. Classic Views"
msgstr ""

#: doc/en/reference.md:501
msgid "Classic views are named display configurations for a space (grid, form, or gallery type). Currently, only the `grid` type is fully supported."
msgstr ""

#: doc/en/reference.md:506
msgid "# Create a grid view on the book catalog"
msgstr ""

#: doc/en/reference.md:508
msgid "  createView("
msgstr ""

#: doc/en/reference.md:510
msgid "    input: { name: \"Catalog\", viewType: grid }"
msgstr ""

#: doc/en/reference.md:511
msgid "  ) { id }"
msgstr ""

#: doc/en/reference.md:516
msgid "  updateView(id: \"...\", input: { name: \"New name\" }) { id name }"
msgstr ""

#: doc/en/reference.md:520
msgid "mutation { deleteView(id: \"...\") }"
msgstr ""

#: doc/en/reference.md:525
msgid "## 6. Custom Views (YAML)"
msgstr ""

#: doc/en/reference.md:527
msgid "Custom views are multi-space dashboards declared in YAML."
msgstr ""

#: doc/en/reference.md:529
msgid "### Editor"
msgstr ""

#: doc/en/reference.md:531
msgid "Click **“Edit”** on a view to open a fullscreen modal composed of:"
msgstr ""

#: doc/en/reference.md:533
msgid "- A **CodeMirror** editor (YAML, monokai theme) for direct YAML editing."
msgstr ""

#: doc/en/reference.md:534
msgid "- An **interactive ERD diagram** on the right: clicking a field automatically generates the corresponding YAML in the editor (widget, columns, `depends_on` if FK detected)."
msgstr ""

#: doc/en/reference.md:536
msgid "Each ERD box has a pseudo-field **`*`** (first row) that adds the space without column restriction (no `columns` key in YAML)."
msgstr ""

#: doc/en/reference.md:537
msgid "Fields are sorted **alphabetically**. Self-relations (e.g., `parent_id → id`) are shown as a loop on the right side of the box."
msgstr ""

#: doc/en/reference.md:539
msgid "### Basic structure"
msgstr ""

#: doc/en/reference.md:543
msgid "  direction: vertical    # or horizontal"
msgstr ""

#: doc/en/reference.md:545
msgid "    - widget: ...        # leaf widget (data grid)"
msgstr ""

#: doc/en/reference.md:546
msgid "    - layout: ...        # nested area (recursive)"
msgstr ""

#: doc/en/reference.md:549
msgid "### Widget"
msgstr ""

#: doc/en/reference.md:552 doc/en/reference.md:623 doc/en/reference.md:640
msgid "widget:"
msgstr ""

#: doc/en/reference.md:553
msgid "  id: unique_identifier   # required, unique in the view"
msgstr ""

#: doc/en/reference.md:554
msgid "  title: \"Displayed title\"   # optional"
msgstr ""

#: doc/en/reference.md:555
msgid "  space: space_name        # Tarantool space name"
msgstr ""

#: doc/en/reference.md:556
msgid "  columns: [field1, field2]  # displayed columns (default: all)"
msgstr ""

#: doc/en/reference.md:557
msgid "  factor: 2                  # weight in parent area (default: 1)"
msgstr ""

#: doc/en/reference.md:558
msgid "  depends_on:                # dependent filtering (optional)"
msgstr ""

#: doc/en/reference.md:559
msgid "    widget: parent_widget_id"
msgstr ""

#: doc/en/reference.md:560
msgid "    field: join_field        # field in THIS space"
msgstr ""

#: doc/en/reference.md:561
msgid "    from_field: id           # field in parent widget (default: id)"
msgstr ""

#: doc/en/reference.md:564
msgid "### Dependencies (inter-widget filtering)"
msgstr ""

#: doc/en/reference.md:566
msgid "When `depends_on` is set, the widget only displays records whose `field` matches the value of `from_field` in the selected row of the parent widget."
msgstr ""

#: doc/en/reference.md:568
msgid "### Proportional factors"
msgstr ""

#: doc/en/reference.md:570
msgid "The `factor` indicates the relative space taken by a child in its area. Example: if widget A has `factor: 2` and widget B `factor: 1`, A takes up 2/3 of the space."
msgstr ""

#: doc/en/reference.md:572
msgid "### Custom columns"
msgstr ""

#: doc/en/reference.md:575
msgid "columns: [prenom, nom, email]   # only these fields, in this order"
msgstr ""

#: doc/en/reference.md:578
msgid "If omitted, all fields of the space are displayed."
msgstr ""

#: doc/en/reference.md:580
msgid "### Full example"
msgstr ""

#: doc/en/reference.md:582
msgid "**Library management** view: book catalog → copies → current loans, with an aggregate widget for loans by genre."
msgstr ""

#: doc/en/reference.md:590
msgid "        title: Book catalog"
msgstr ""

#: doc/en/reference.md:598
msgid "              title: Copies"
msgstr ""

#: doc/en/reference.md:607
msgid "              id: emprunts"
msgstr ""

#: doc/en/reference.md:608
msgid "              title: Current loans"
msgstr ""

#: doc/en/reference.md:618
msgid "### Aggregate widget"
msgstr ""

#: doc/en/reference.md:620
msgid "A widget of type `aggregate` displays a read-only summary table, computed server-side by iterating over the space. It is equivalent to a SQL `GROUP BY`."
msgstr ""

#: doc/en/reference.md:624 doc/en/reference.md:641
msgid "  type: aggregate"
msgstr ""

#: doc/en/reference.md:625 doc/en/reference.md:642
msgid "  title: \"Loans by genre\""
msgstr ""

#: doc/en/reference.md:626 doc/en/reference.md:643
msgid "  space: emprunts"
msgstr ""

#: doc/en/reference.md:627 doc/en/reference.md:644
msgid "  groupBy: [genre_id]"
msgstr ""

#: doc/en/reference.md:628 doc/en/reference.md:645
msgid "  aggregate:"
msgstr ""

#: doc/en/reference.md:629 doc/en/reference.md:646
msgid "    - fn: count"
msgstr ""

#: doc/en/reference.md:630 doc/en/reference.md:647
msgid "      as: nb_emprunts"
msgstr ""

#: doc/en/reference.md:633
msgid "The `as` alias is optional: if absent, the generated column name is `fn_field` (e.g., `avg_annee`) or `count` for `COUNT(*)`."
msgstr ""

#: doc/en/reference.md:635
msgid "#### Computed columns"
msgstr ""

#: doc/en/reference.md:637
msgid "You can add client-side computed columns via the `computed` key. Each entry provides an alias (`as`) and a JavaScript expression (`expr`) evaluated on each aggregated row. The `row` object contains all `groupBy` fields and `aggregate` aliases."
msgstr ""

#: doc/en/reference.md:648
msgid "  computed:"
msgstr ""

#: doc/en/reference.md:649
msgid "    - as: label"
msgstr ""

#: doc/en/reference.md:650
msgid "      expr: \"row.genre_id + ' (' + row.nb_emprunts + ')'\""
msgstr ""

#: doc/en/reference.md:651
msgid "    - as: status"
msgstr ""

#: doc/en/reference.md:652
msgid "      expr: \"row.nb_emprunts > 10 ? 'Active' : 'Low activity'\""
msgstr ""

#: doc/en/reference.md:655
msgid "> **Note:** `computed` expressions are pure JavaScript (not MoonScript); they run in the browser after receiving the aggregated data."
msgstr ""

#: doc/en/reference.md:657
msgid "![Aggregate widget](../img/aggregate-widget.png)"
msgstr ""

#: doc/en/reference.md:662 doc/en/reference.md:745
msgid "# List"
msgstr ""

#: doc/en/reference.md:663
msgid "query { customViews { id name yaml } }"
msgstr ""

#: doc/en/reference.md:667
msgid "  createCustomView(input: {"
msgstr ""

#: doc/en/reference.md:668
msgid "    name: \"Dashboard\","
msgstr ""

#: doc/en/reference.md:669
msgid "    yaml: \"layout:\\n  direction: vertical\\n  children: []\\n\""
msgstr ""

#: doc/en/reference.md:675
msgid "  updateCustomView(id: \"...\", input: { yaml: \"...\" }) { id yaml }"
msgstr ""

#: doc/en/reference.md:679
msgid "mutation { deleteCustomView(id: \"...\") }"
msgstr ""

#: doc/en/reference.md:681
msgid "# Direct aggregate query: loans by genre"
msgstr ""

#: doc/en/reference.md:683
msgid "  aggregateSpace("
msgstr ""

#: doc/en/reference.md:684
msgid "    spaceName: \"emprunts\","
msgstr ""

#: doc/en/reference.md:685
msgid "    groupBy: [\"genre_id\"],"
msgstr ""

#: doc/en/reference.md:686
msgid "    aggregate: ["
msgstr ""

#: doc/en/reference.md:687
msgid "      { fn: \"count\", as: \"nb_emprunts\" }"
msgstr ""

#: doc/en/reference.md:688
msgid "    ]"
msgstr ""

#: doc/en/reference.md:689
msgid "  )"
msgstr ""

#: doc/en/reference.md:695
msgid "## 7. Authentication"
msgstr ""

#: doc/en/reference.md:697
msgid "TGui uses **Bearer tokens** (SHA-256 + salt, stored in Tarantool session). The token is persisted in `localStorage` and automatically sent by the client."
msgstr ""

#: doc/en/reference.md:699
msgid "### Login flow"
msgstr ""

#: doc/en/reference.md:703
msgid "  login(username: \"alice\", password: \"secret\") {"
msgstr ""

#: doc/en/reference.md:704
msgid "    token"
msgstr ""

#: doc/en/reference.md:705
msgid "    user { id username email groups { id name } }"
msgstr ""

#: doc/en/reference.md:710
msgid "The token is then sent in the HTTP header:"
msgstr ""

#: doc/en/reference.md:713
msgid "Authorization: Bearer <token>"
msgstr ""

#: doc/en/reference.md:716
msgid "### Logout"
msgstr ""

#: doc/en/reference.md:719
msgid "mutation { logout }"
msgstr ""

#: doc/en/reference.md:722
msgid "### Current user"
msgstr ""

#: doc/en/reference.md:725
msgid "query { me { id username email groups { id name } } }"
msgstr ""

#: doc/en/reference.md:728
msgid "### Change own password"
msgstr ""

#: doc/en/reference.md:732
msgid "  changePassword(currentPassword: \"old\", newPassword: \"new\")"
msgstr ""

