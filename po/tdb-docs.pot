#: doc/en/get-started.md:137 doc/en/reference.md:143
msgid "parts = {}"
msgstr ""

#: doc/en/get-started.md:138 doc/en/reference.md:144
msgid "table.insert(parts, @prenom) if @prenom and @prenom != \"\""
msgstr ""

#: doc/en/get-started.md:139 doc/en/reference.md:145
msgid "table.insert(parts, @particule) if @particule and @particule != \"\""
msgstr ""

#: doc/en/get-started.md:140 doc/en/reference.md:146
msgid "table.insert(parts, @nom) if @nom and @nom != \"\""
