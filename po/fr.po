msgstr ""

#. type: Plain text
#: doc/en/reference.md:928
msgid "### Import modes"
msgstr ""

#. type: Plain text
#: doc/en/reference.md:933
#, no-wrap
msgid ""
"| Mode         | Behavior |\n"
"|--------------|----------|\n"
"| **Merge**    | Creates missing spaces, fields, relations, views, and groups. Existing items (same name) are left untouched. |\n"
"| **Replace**  | First deletes all existing spaces and groups, then recreates everything from the snapshot. Warning: all existing data is lost. |\n"
msgstr ""

#. type: Plain text
#: doc/en/reference.md:935
msgid ""
"The result indicates the number of items created, ignored, and any errors."
msgstr ""

#. type: Plain text
#: doc/en/reference.md:937
msgid "### Corresponding GraphQL API"
msgstr ""

#. type: Plain text
#: doc/en/reference.md:943
#, no-wrap
msgid ""
"```graphql\n"
"# Export\n"
"query Export($includeData: Boolean!) {\n"
"  exportSnapshot(includeData: $includeData)\n"
"}\n"
msgstr ""

#. type: Plain text
#: doc/en/reference.md:953
#, no-wrap
msgid ""
"# Diff preview\n"
"query Diff($yaml: String!) {\n"
"  diffSnapshot(yaml: $yaml) {\n"
"    spacesToCreate\n"
"    spacesToDelete\n"
"    customViewsToCreate\n"
"    customViewsToUpdate\n"
"  }\n"
"}\n"
msgstr ""

#. type: Plain text
#: doc/en/reference.md:964
#, no-wrap
msgid ""
"# Import\n"
"mutation Import($yaml: String!, $mode: ImportMode!) {\n"
"  importSnapshot(yaml: $yaml, mode: $mode) {\n"
"    ok\n"
"    created\n"
"    skipped\n"
"    errors\n"
"  }\n"
"}\n"
"```\n"
msgstr ""

